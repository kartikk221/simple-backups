{
    "name": "simple-backups",
    "version": "1.1.1",
    "description": "Simple yet unopinionated zero-dependency package to easily setup automatic backups for any data source that persists to any storage mechanism.",
    "type": "module",
    "main": "./src/index.js",
    "types": "./src/index.d.ts",
    "exports": {
        ".": {
            "types": "./src/index.d.ts",
            "import": "./src/index.js",
            "default": "./src/index.js"
        }
    },
    "files": [
        "src",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "test": "node --test && tsc --project tsconfig.json"
    },
    "keywords": [
        "backup",
        "backups",
        "storage",
        "scheduler",
        "nodejs",
        "javascript",
        "s3-bucket",
        "unopinionated",
        "zero-dependency"
    ],
    "license": "MIT",
    "engines": {
        "node": ">=20"
    },
    "devDependencies": {
        "typescript": "7.0.2"
    }
}
